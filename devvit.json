{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "markdown-app",
  "permissions": {
    "http": {
      "enable": false
    },
    "media": false,
    "realtime": false,
    "redis": true,
    "reddit": {
      "enable": true,
      "asUser": [
        "SUBMIT_POST",
        "SUBMIT_COMMENT"
      ]
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "settings": {
    "subreddit": {
      "requirePostFlair": {
        "type": "boolean",
        "label": "Require post flair",
        "defaultValue": false
      },
      "postBodyHeight": {
        "type": "number",
        "label": "Line height for post body",
        "helpText": "This is how tall the post body field will be, in number of lines. Positive whole numbers only. Note: In iOS, anything above approximately 11 lines will be ignored by Reddit.",
        "defaultValue": 10
      },
      "commentBodyHeight": {
        "type": "number",
        "label": "Line height for comment body",
        "helpText": "This is how tall the comment body field will be, in number of lines.",
        "defaultValue": 6
      },
      "replaceEmDash": {
        "type": "boolean",
        "label": "Replace em-dash-and-hyphen",
        "helpText": "If enabled, a combination of em-dash followed immediately by a hyphen (—-) will be replaced with three hyphens (---) to make horizontal rules easier on mobile.",
        "defaultValue": false
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create post",
        "description": "in Markdown",
        "forUserType": "user",
        "location": [
          "subreddit"
        ],
        "endpoint": "/internal/menu/create-post"
      },
      {
        "label": "Comment/reply",
        "description": "in Markdown",
        "forUserType": "user",
        "location": [
          "comment",
          "post"
        ],
        "endpoint": "/internal/menu/create-comment"
      }
    ]
  },
  "forms": {
    "createPost": "/internal/forms/create-post-submit",
    "createComment": "/internal/forms/create-comment-submit"
  },
  "triggers": {
    "onAppUpgrade": "/internal/triggers/on-app-upgrade"
  },
  "marketingAssets": {
    "icon": "assets/ma-icon.png"
  },
  "dev": {
    "subreddit": "CapitalOneBank"
  }
}